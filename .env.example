# Copy this file to `.env` and fill in only what you need.
# Everything here is OPTIONAL — the default pipeline (public medical dataset + auto
# hard-negative mining) runs with no keys at all.

# --- Optional: OpenAI, used for two things (both need OPENAI_API_KEY) ---
#   1. LLM-based synthetic clinical triplet generation (core/llm_triplet_gen.py)
#   2. Closed-source embedding baselines in the benchmark (BASELINE_MODELS below)
# If OPENAI_API_KEY is empty, both are skipped automatically.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
# $ per 1M tokens for the OpenAI embedding baselines (text-embedding-3-small default).
# OPENAI_EMBEDDING_PRICE_PER_1M=0.02

# --- Optional: push the fine-tuned model to the Hugging Face Hub ---
HF_TOKEN=

# --- Optional overrides (any settings field works in UPPER_CASE) ---
# DOMAIN=medembed
# BASE_MODEL=BAAI/bge-base-en-v1.5
# Fine-tune several OPEN-SOURCE base models in one run (comma-separated; blank = single):
# BASE_MODELS=BAAI/bge-small-en-v1.5,intfloat/e5-small-v2,thenlper/gte-small
# CLOSED-SOURCE encode-only baselines for the benchmark (never fine-tuned; need OPENAI_API_KEY):
# BASELINE_MODELS=openai:text-embedding-3-small,openai:text-embedding-3-large
# SAMPLE_SIZE=5000
