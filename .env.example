# Copy this file to `.env` and fill in only what you need.
# Everything here is OPTIONAL — the default pipeline (public medical dataset + auto
# hard-negative mining) runs with no keys at all.

# --- Optional: LLM-based synthetic clinical triplet generation (core/llm_triplet_gen.py) ---
# If OPENAI_API_KEY is empty, the LLM path is skipped automatically.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# --- Optional: push the fine-tuned model to the Hugging Face Hub ---
HF_TOKEN=

# --- Optional overrides (any settings field works in UPPER_CASE) ---
# DOMAIN=medembed
# BASE_MODEL=BAAI/bge-base-en-v1.5
# SAMPLE_SIZE=5000
